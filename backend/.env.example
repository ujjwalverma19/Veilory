# ──────────────────────────────────────────────
# Veilory Backend — Environment Configuration
# ──────────────────────────────────────────────
# Copy this file to .env and fill in production values.
# NEVER commit .env with real secrets to version control.

# ─── Application ─────────────────────────────
PROJECT_NAME=Veilory
API_V1_STR=/api/v1
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# ─── PostgreSQL ──────────────────────────────
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password_here
POSTGRES_DB=veilory_db

# ─── JWT Authentication ─────────────────────
# Generate a strong key: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_ME_IN_PRODUCTION
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=11520

# .env example for backend production
SECRET_KEY=YOUR_RANDOM_64_BYTE_BASE64_STRING
FRONTEND_URL=https://veilory.online
COOKIE_DOMAIN=.veilory.online
USE_COOKIE_AUTH=false
ACCESS_TOKEN_EXPIRE_MINUTES=1440
POSTGRES_SERVER=YOUR_POSTGRES_HOST
POSTGRES_PORT=5432
POSTGRES_USER=YOUR_DB_USER
POSTGRES_PASSWORD=YOUR_DB_PASSWORD
POSTGRES_DB=veilory_db
USE_SQLITE=false
CHROMA_DB_PATH=/app/chroma_db
